# Required for live traffic predictions (GRU, LSTM, DCRNN models)
# Register at https://pems.dot.ca.gov to obtain a key
# Without this, the system falls back to MockProvider automatically
PEMS_API_KEY=

# Optional overrides
# PEMS_BASE_URL=https://pems.dot.ca.gov
# PREDICTION_HORIZON_STEPS=12

# Path overrides (useful when running from a non-root directory or in Docker)
# DATA_DIR=data
# MODELS_DIR=models
# CACHE_DIR=cache
# GRAPH_NPZ_PATH=data/graph.npz
