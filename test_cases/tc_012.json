{
  "test_case_id": "tc_012",
  "description": "Travel time conversion formula verification at key flow values",
  "category": "travel_time",
  "input": {
    "test_flows": [
      0,
      100,
      351,
      500,
      800,
      1000,
      1500
    ]
  },
  "expected_output": {
    "flow_0": {
      "speed_kmh": 60.0,
      "note": "Zero flow -> speed limit"
    },
    "flow_100": {
      "speed_kmh": 60.0,
      "note": "Below threshold -> speed limit"
    },
    "flow_351": {
      "speed_kmh": 60.0,
      "note": "At threshold -> speed limit"
    },
    "flow_500": {
      "speed_kmh_range": [
        55,
        60
      ],
      "note": "Light traffic"
    },
    "flow_800": {
      "speed_kmh_range": [
        50,
        58
      ],
      "note": "Moderate traffic"
    },
    "flow_1000": {
      "speed_kmh_range": [
        42,
        52
      ],
      "note": "Heavy traffic"
    },
    "flow_1500": {
      "speed_kmh": 32.0,
      "note": "At capacity"
    }
  }
}